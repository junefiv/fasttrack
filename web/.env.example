# 복사 후 이름을 .env.local 로 저장하고 값을 채우세요 (.env.local 은 Git에 올리지 마세요)
# 이 파일에는 실제 키를 넣지 마세요. 예시만 두고, 값은 AI Studio / Supabase 대시보드에서 발급받습니다.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_jwt_here

# Google AI Studio / Gemini API (브라우저에 노출되므로 프로덕션에서는 백엔드 프록시 권장)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# 선택: 기본값 gemini-2.5-flash
# VITE_GEMINI_MODEL=gemini-2.5-flash

# 교재 RAG용 임베딩 (기본 gemini-embedding-001, 계정에 따라 text-embedding-004 등)
# VITE_GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# 교재 PDF 업로드(/ebook/upload). 공개 배포 시 비활성화 권장(변수 제거 또는 false)
# VITE_ENABLE_EBOOK_UPLOAD=true

# 모의고사·드릴·카탈로그 문항 제출 등 Supabase fasttrack_* user_id
# 미설정 시 코드 기본값 11111111-1111-4111-8111-111111111111 (공용 프로토타입 사용자)
# VITE_FASTTRACK_DEV_USER_ID=00000000-0000-4000-8000-000000000001
